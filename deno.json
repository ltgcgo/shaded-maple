{
	"name": "@ltgc/shaded-maple",
	"version": "0.0.1-pre.1+b.1",
	"license": "LGPL-3.0-only",
	"imports": {
		"@ltgc/rochelle": "jsr:@ltgcgo/rochelle@^0.2.9"
	},
	"exports": {
		"./shade": "./dist/basic.d.mts",
		"./shadeSw": "./dist/bridge.d.mts"
	},
	"publish": {
		"include": [
			"dist/README.md",
			"dist/*.mjs",
			"dist/*.mts",
			"libs/**/*.d.mts",
			"README.md"
		]
	},
	"compilerOptions": {
		"lib": [
			"ES5", "ES6",
			"ES2017", "ES2018", "ES2019", "ES2020",
			"ES2021", "ES2022", "ES2023", "ESNext",
			"DOM", "WebWorker"
		]
	},
	"unstable": [
		"broadcast-channel",
		"net",
		"webgpu"
	],
	"fmt": {
		"useTabs": true,
		"lineWidth": 200,
		"indentWidth": 4,
		"semiColons": true,
		"exclude": [
			"*",
			"**/*"
		]
	},
	"lint": {
		"exclude": [
			"*"
		],
		"rules": {
			"tags": [],
			"include": [
				"constructor-super",
				"getter-return",
				"no-await-in-sync-fn",
				"no-cond-assign",
				"no-constant-condition",
				"no-dupe-args",
				"no-dupe-class-members",
				"no-dupe-else-if",
				"no-dupe-keys",
				"no-duplicate-case",
				"no-eval",
				"no-extra-boolean-cast",
				"no-extra-non-null-assertion",
				"no-invalid-regexp",
				"no-irregular-whitespace",
				"no-misused-new",
				"no-new-symbol",
				"no-node-globals",
				"no-non-null-asserted-optional-chain",
				"no-obj-calls",
				"no-process-global",
				"no-redeclare",
				"no-regex-spaces",
				"no-self-assign",
				"no-setter-return",
				"no-shadow-restricted-names",
				"no-sloppy-imports",
				"no-this-before-super",
				"no-throw-literal",
				"no-unused-labels",
				"no-unused-vars",
				"no-with",
				"require-yield",
				"use-isnan",
				"valid-typeof"
			]
		}
	},
	"nodeModulesDir": false,
	"npmRegistry": "http://256.257.258.259:65536/"
}
